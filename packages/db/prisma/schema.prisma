// Prisma スキーマ
// 根拠: docs/architecture/03-data-model.md / ADR-0001 / ADR-0004 / ADR-0008

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CoefficientType {
  SEASON
  DAY_OF_WEEK
  LEAD_TIME
}

model RoomType {
  id             Int    @id @default(autoincrement())
  code           String @unique
  name           String
  capacity       Int?
  inventoryCount Int

  reservations Reservation[]
  basePrices   BasePrice[]

  @@map("room_types")
}

model Plan {
  id       Int     @id @default(autoincrement())
  code     String  @unique
  name     String
  mealType String?

  reservations Reservation[]
  basePrices   BasePrice[]

  @@map("plans")
}

model Reservation {
  id              Int       @id @default(autoincrement())
  reservationCode String?
  bookedDate      DateTime  @db.Date
  checkInDate     DateTime  @db.Date
  checkOutDate    DateTime  @db.Date
  nights          Int
  // CSV「室数」列。1 行 = 1 室の暗黙前提を排除し、複数室予約を集計に正しく反映する (issue #59)。
  roomCount       Int       @default(1)
  bookingChannel  String?
  roomTypeId      Int
  planId          Int
  adults          Int
  children        Int
  infants         Int
  totalAmount     Decimal   @db.Decimal(12, 2)
  adultUnitPrice  Decimal?  @db.Decimal(12, 2)
  childUnitPrice  Decimal?  @db.Decimal(12, 2)
  infantUnitPrice Decimal?  @db.Decimal(12, 2)
  cancelDate      DateTime? @db.Date

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  plan     Plan     @relation(fields: [planId], references: [id])

  @@index([checkInDate])
  @@index([bookedDate])
  @@index([roomTypeId, planId, checkInDate])
  @@map("reservations")
}

model BasePrice {
  id            Int       @id @default(autoincrement())
  roomTypeId    Int
  planId        Int
  amount        Decimal   @db.Decimal(12, 2)
  priceMin      Decimal   @db.Decimal(12, 2)
  priceMax      Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  plan     Plan     @relation(fields: [planId], references: [id])

  @@unique([roomTypeId, planId, effectiveFrom])
  @@map("base_prices")
}

model PriceCoefficient {
  id         Int             @id @default(autoincrement())
  type       CoefficientType
  key        String
  value      Decimal         @db.Decimal(6, 4)
  computedAt DateTime        @db.Timestamptz(6)
  source     String?

  @@unique([type, key, computedAt])
  @@index([type, key])
  @@map("price_coefficients")
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  name        String?
  role        Role
  status      UserStatus
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  lastLoginAt DateTime?  @db.Timestamptz(6)
  invitedById Int?

  invitedBy    User?        @relation("UserInvitations", fields: [invitedById], references: [id])
  invitedUsers User[]       @relation("UserInvitations")
  invitations  Invitation[] @relation("InvitationCreator")
  auditLogs    AuditLog[]

  @@map("users")
}

model Invitation {
  id          Int       @id @default(autoincrement())
  email       String
  role        Role      @default(MEMBER)
  invitedById Int
  expiresAt   DateTime  @db.Timestamptz(6)
  usedAt      DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  invitedBy User @relation("InvitationCreator", fields: [invitedById], references: [id])

  @@index([email])
  @@map("invitations")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  target    String?
  payload   Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("audit_logs")
}
