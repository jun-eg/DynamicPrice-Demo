{
  "name": "@app/api",
  "version": "0.0.0",
  "private": true,
  "description": "価格計算・データ API (NestJS)",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import @swc-node/register/esm-register --watch src/main.ts",
    "start": "node --import @swc-node/register/esm-register src/main.ts",
    "lint": "eslint --no-error-on-unmatched-pattern --max-warnings=0 \"src/**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@app/db": "*",
    "@app/shared": "*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.32",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "typescript": "^5.7.3"
  }
}
