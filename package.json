{
  "name": "dynamic-price-demo",
  "version": "0.0.0",
  "private": true,
  "description": "旅館向け動的価格決定支援ツール (試験運用)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:workspaces": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "db:seed-master": "tsx scripts/seed/master.ts",
    "db:seed-reservations": "tsx scripts/seed/reservations.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.17.10",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "iconv-lite": "^0.6.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "dependencies": {
    "@app/db": "*"
  }
}
